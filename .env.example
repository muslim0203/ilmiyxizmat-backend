# Railway PostgreSQL — Railway dashboard dan olinadi
DATABASE_URL=postgresql://user:password@host:5432/railway

# JWT — kamida 32 ta tasodifiy belgi (https://randomkeygen.com)
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here

# Admin parol — bcrypt hash (node -e "require('bcryptjs').hash('parolingiz',10).then(console.log)" bilan yarating)
ADMIN_PASSWORD_HASH=$2b$10$examplehashhere

# Frontend URL — CORS uchun (masalan: https://ilmiyxizmat.uz)
FRONTEND_URL=http://localhost:5173

# Google Gemini API key — frontend dan ko'chiriladi
GEMINI_API_KEY=your_gemini_api_key_here

# Port (Railway avtomatik belgilaydi)
PORT=3000
